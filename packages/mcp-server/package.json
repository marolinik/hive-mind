{
  "name": "@hive-mind/mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing hive-mind memory (21 tools + 4 resources) over stdio for Claude Code, Claude Desktop, Codex, and any MCP-compatible client",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hive-mind-memory-mcp": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tools/*": {
      "types": "./dist/tools/*.d.ts",
      "import": "./dist/tools/*.js"
    },
    "./resources/*": {
      "types": "./dist/resources/*.d.ts",
      "import": "./dist/resources/*.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@hive-mind/core": "0.1.0",
    "@hive-mind/wiki-compiler": "0.1.0",
    "zod": "^3.23.0"
  },
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marolinik/hive-mind.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/marolinik/hive-mind/tree/master/packages/mcp-server#readme",
  "bugs": { "url": "https://github.com/marolinik/hive-mind/issues" },
  "author": "Egzakta Group d.o.o. <hello@egzakta.com> (https://egzakta.com)",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "codex",
    "memory",
    "ai",
    "hive-mind"
  ],
  "engines": { "node": ">=20" }
}
