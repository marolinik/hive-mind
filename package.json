{
  "name": "hive-mind",
  "version": "0.4.0",
  "description": "Local-first AI memory system with semantic search, knowledge graph, wiki compiler, and MCP server. Compatible with Claude Code, Codex, Hermes, and any MCP client.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:seed": "node e2e/seed.mjs",
    "e2e:serve": "node e2e/serve.mjs",
    "e2e:http": "node e2e/http-verify.mjs",
    "e2e:visual": "playwright test -c e2e/playwright.config.ts",
    "clean": "tsc --build --clean && rm -rf packages/*/dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marolinik/hive-mind"
  },
  "keywords": [
    "memory",
    "ai",
    "mcp",
    "knowledge-graph",
    "wiki",
    "local-first",
    "semantic-search"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.1.8"
  }
}
