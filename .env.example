# hive-mind — environment template. Copy to `.env` and fill only what you need.
# Most usage works with ZERO config (in-process embedder + local SQLite).
# Set keys only for cloud embedders, cognify/verify LLM calls, or benchmarks.

# ── Embedding provider ──────────────────────────────────────────────
# "auto" (default) tries: inprocess → ollama → api → mock
# HIVE_MIND_EMBEDDING_PROVIDER=auto

# Ollama — REQUIRED to run the LoCoMo / recall-stress benchmarks.
#   Install https://ollama.com, then:  ollama pull nomic-embed-text
# The stored vectors are 1024-d nomic; running against a DB built with a
# DIFFERENT embedder silently corrupts retrieval (no error, just wrong results).
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=nomic-embed-text

# ── LLM keys (cognify extraction, verify, benchmark answerers/judges) ──
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# VOYAGE_API_KEY=            # alt cloud embedder (HIVE_MIND_EMBEDDING_PROVIDER=voyage)
# VOYAGE_MODEL=voyage-3
# DASHSCOPE_API_KEY=         # Qwen (intl tenant) — benchmark answerer/judge
# MINIMAX_API_KEY=           # MiniMax — benchmark judge

# ── Storage / tier (optional overrides) ─────────────────────────────
# HIVE_MIND_DATA_DIR=~/.hive-mind
# HIVE_MIND_TIER=free
